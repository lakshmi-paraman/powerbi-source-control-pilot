table pbi_raw_activity_log
	lineageTag: 5392d722-512b-483f-9ce4-7dbda2f79286
	sourceLineageTag: 7a1bb137-6275-4028-a5c4-9dce3f4ca54e

	measure 'Dataset Count' =
			
			DISTINCTCOUNT(pbi_raw_activity_log[Dataset_ID]
			)
		formatString: 0
		lineageTag: b4beeedf-1d5f-46a3-94ca-7e05add751d5

		changedProperty = Name

	measure 'Workspace Rank' = ```
			
			RANKX(
			    ALLSELECTED(pbi_raw_activity_log[Workspace_ID]),
			    [Dataset Count],
			    ,
			    DESC,
			    DENSE
			)
			
			```
		formatString: 0
		lineageTag: 8d6746ad-242e-44ae-9cff-c11bd32435b6

		changedProperty = Name

	measure 'Workspace Color' =
			
			SWITCH(
			    TRUE(),
			    [Workspace Rank] = 1, "#3C3AC4",   -- Blue
			    [Workspace Rank] = 2, "#ff7f0e",   -- Orange
			    [Workspace Rank] = 3, "#2ca02c",   -- Green
			    "#D9D9D9"                          -- Gray
			)
		lineageTag: 44a61132-34a4-4c04-9a6a-cfc9deedcfc3

		changedProperty = Name

	measure 'min date' = EXTERNALMEASURE("min date", STRING, "DirectQuery to AS - Governance_Dataset_V1.1")
		formatString: General Number
		lineageTag: 0c2004bc-7fd4-4585-ad3c-d28926fbbee6
		sourceLineageTag: 54817a68-3641-4cb0-8121-009426e64142
		dataCategory: Uncategorized

	measure 'max date' = EXTERNALMEASURE("max date", STRING, "DirectQuery to AS - Governance_Dataset_V1.1")
		formatString: General Number
		lineageTag: f1985923-ba2a-4b4c-a235-ac8c85328cd8
		sourceLineageTag: ca7aa335-6167-4b0e-8e96-28c096ce61d2
		dataCategory: Uncategorized

	measure 'No of days' = EXTERNALMEASURE("No of days", INTEGER, "DirectQuery to AS - Governance_Dataset_V1.1")
		formatString: 0
		lineageTag: cb0b3983-ac67-4139-a63a-8531ea2e6d91
		sourceLineageTag: 3bcc9be0-69db-41ca-a773-e46244368ed9
		dataCategory: Uncategorized

	measure 'Event Max Date' = MAX(pbi_raw_activity_log[EventDate])
		formatString: General Date
		lineageTag: 769df3e8-4079-4310-b6b5-0d0d948eb0d0

		changedProperty = Name

	measure 'Event Min Date' = min(pbi_raw_activity_log[EventDate])
		formatString: General Date
		lineageTag: 1f955b7a-aa61-4e20-8349-13e194bf86ff

		changedProperty = Name

	measure Days = DISTINCTCOUNT(pbi_raw_activity_log[EventDate]) & " Days "
		lineageTag: 80ec118b-6b48-4f22-97e8-484e3880a3f9

		changedProperty = Name

	measure 'Unique users per report' = CALCULATE(DISTINCTCOUNT(pbi_raw_activity_log[User_ID]),pbi_raw_activity_log[Activity]="ViewReport")
		formatString: 0
		lineageTag: f945bb15-5c98-4579-8239-9e31820b91dd

		changedProperty = Name

	measure 'Last Viewed Date' = CALCULATE(max(pbi_raw_activity_log[EventDate]),pbi_raw_activity_log[Activity] IN {"ViewReport","OpenReport","AccessReport"})
		formatString: General Date
		lineageTag: 019ae4d0-55bd-4de5-8496-c97911a8db95

		changedProperty = Name

	measure 'Days Since Last Access' =
			
			VAR LastDate1 = [Last Viewed Date]
			RETURN
			IF(
			    ISBLANK(LastDate1),
			    BLANK(),
			    DATEDIFF(LastDate1, TODAY(), DAY)
			)
		formatString: 0
		lineageTag: c665541b-ab4f-46dd-af35-71606e54b826

		changedProperty = Name

	measure 'Not Accessed 30 Days' =
			
			VAR LastDate1 = [Last Viewed Date]
			RETURN
			IF(
			    ISBLANK(LastDate1) ||
			    LastDate1 <= TODAY() - 60,
			    1,
			    0
			)
		formatString: 0
		lineageTag: 9fe3037b-dbbd-4766-9cc1-66a8758d68cc

		changedProperty = Name

	measure 'Usage Status' =
			
			VAR LastDate1 = [Last Viewed Date]
			VAR DaysIdle =
			IF(ISBLANK(LastDate1), 9999, DATEDIFF(LastDate1,TODAY(),DAY))
			RETURN
			SWITCH(
			TRUE(),
			ISBLANK(LastDate1), "Never Viewed",
			DaysIdle > 180, "Archive Candidate",
			DaysIdle > 90, "Dormant",
			DaysIdle > 60, "Cold",
			"Active"
			)
		lineageTag: 41d6755e-5425-471c-b6d7-169ed173f77e

		changedProperty = Name

	measure 'Total Report Views' = ```
			
			CALCULATE(
			    COUNTROWS(pbi_raw_activity_log),
			    pbi_raw_activity_log[Activity] = "ViewReport"
			)
			
			```
		formatString: 0
		lineageTag: 0548fa1f-997c-476f-b757-2d73f204bd5d

		changedProperty = Name

	measure 'Distinct Reports Viewed' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(pbi_raw_activity_log[Report_ID]),
			    pbi_raw_activity_log[Activity] = "ViewReport"
			)
			
			```
		formatString: 0
		lineageTag: 2173fdd4-8c58-4eba-b6b6-cd488e1be6a2

		changedProperty = Name

	measure 'Active Report Users' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(pbi_raw_activity_log[User_ID]),
			    pbi_raw_activity_log[Activity] = "ViewReport"
			)
			
			```
		formatString: 0
		lineageTag: d4aaf184-1d7c-4361-a007-498710101dfd

		changedProperty = Name

	measure 'Active Workspaces (Reports)' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(pbi_raw_activity_log[Workspace_ID]),
			    pbi_raw_activity_log[Activity] = "ViewReport"
			)
			
			```
		formatString: 0
		lineageTag: c9f7f353-13c8-43dd-a719-95d4a553e867

		changedProperty = Name

	measure 'Avg Views per Report' =
			
			DIVIDE([Total Report Views], [Distinct Reports Viewed])/100
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c978bace-0a56-4599-b508-a31a425dd34c

		changedProperty = Name

		changedProperty = FormatString

