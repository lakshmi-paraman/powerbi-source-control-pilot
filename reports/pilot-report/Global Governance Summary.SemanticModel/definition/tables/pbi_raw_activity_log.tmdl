	column EventDate =
			
			DATE(
			    VALUE(LEFT([CreationTime], 4)),
			    VALUE(MID([CreationTime], 6, 2)),
			    VALUE(MID([CreationTime], 9, 2))
			)
		formatString: dd-mmm-yy
		lineageTag: b57df861-cc79-4d78-90fd-435610174812
		summarizeBy: none

